  "id": 16,
  "title": {
    "arabic": "كَلَامٌ قَدِيْمٌ",
    "latin": "Kalam Qadim"
  },
  "content": [
    [
      "كَلَامٌ قَدِيْمٌ لَا يُمَلُّ سَمَاعُهُ",
      "تَنَزَّهَ عَنْ قَوْلٍ وَفِعْلٍ وَنِيَّةٍ"
    ],
    [
      "بِهٖٓ أَشْتَفٖى مِنْ كُلِّ دَآءٍ وَنُوْرُهُ",
      "دَلِيْلٌ لِقَلْبِيْ عِنْدَ جَهْلِيْ وَحَيْرَتِيْ"
    ],
    [
      "فَيَا رَبِّ مَتِّعْنِيْ بِسِرِّ حُرُوْفِهٖ",
      "وَنَوِّرْ بِهٖ قَلْبِيْ وَسَمْعِيْ وَمُقْلَتِيْ"
    ],
    [
      "وَصَلِّ وَسَلِّمْ يَا اِلٰهِيْ عَلَى النَّبِيْ",
      "وَاٰلٍ وَاَصْحَابٍ بِهِمْ نِلْتُ بُغْيَتِيْ"
    ],
    [
      "وَيَا رَبِّ زِدْنِيْ بِهٖ عِلْمًا وَّحِكْمَةً",
      "بِجَاهِ النَّبِيِّ مَنْ جَآءَنَا بِالْهِدَايَةْ"
    ],
    [
      "عَلَيْهِ صَلَاةُ اللّٰهِ ثُمَّ سَلَامُهُ",
      "وَاٰلٍ وَاَصْحَابٍ بِهِمْ نِلْتُ حَاجَتِيْ"
    ],
    [
      "سَأَلْتُكَ رَبِّيْ صِحَّةَ الْقَلْبِ وَالْجَسَدِ",
      "وَعَافِيَةَ الْأَبْدَانِ وَالْأَهْلِ وَالْوَلَدْ"
    ],
    [
      "وَطُوْلَ حَيَاةٍ فِيْ كَمَالِ اسْتِقَامَةٍ",
      "وَحِفْظًا مِّنَ الْإِعْجَابِ وَالْكِبْرِ وَالْحَسَدْ"
    ],
    [
      "وَرِزْقًا حَلَالًا وَاسِعًا غَيْرَ قَاصِرِِ",
      "يَكُوْنُ لَنَا عَوْنًا عَلٰى مَنْهَجِ الرَّشَدْ"
    ],
    [
      "وَحُسْنَ الْأٰدَاءِ لِلْحُقُوْقِ جَمِيْعِهَا",
      "بِفَضْلِكَ يَا اَللّٰهُ يَا بَرُّ يَا صَمَدْ"
    ],
    [
      "بِجَاهِ النَّبِيِّ الْمُصْطَفٰى أَشْرَفِ الْوَرٰى",
      "وَاَفْضَلِ مَـنْ صَامَ وَحَجَّ وَمَنْ سَجَدْ"
    ],
    [
      "وَصَلِّ وَسَلِّمْ يَا إِلٰهِيْ سَرْمَدًا",
      "عَلَى الْمُصْطَفٰى وَالْاٰلِ مَعْ كُلِّ مَنْ سَجَدْ"
    ]
  ]
}
