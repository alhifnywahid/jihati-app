  "id": 42,
  "title": {
    "arabic": "اَلتَّوَسُّلُ بِالنَّظْمِ",
    "latin": "Tawassul Bin Nadham"
  },
  "content": [
    [
      "تَوَسَّلْنَا بِكَ يَا اُسْتَاذَنَا مَسْعُوْدُ",
      "لَكَ عُلُومٌ بِهَا حَيَاتُنَا سَعِيْدُ"
    ],
    [
      "تَوَسَّلْنَا بِجَاهِ اُسْتَاذِنَا مَسْعُوْدُ",
      "إِلٰى سَبِيْلِ الْهُدٰى بِفَضْلِكَ نُرْشَدُ"
    ],
    [
      "وَنَحْنُ نَرْتَجٖى مِنْكَ شَيْخَنَا مَسْعُوْدُ",
      "كُلَّ عُلُوْمٍ بِّهَا اَحْوَالُنَا مَحُمُوْدُ"
    ],
    [
      "نَشْكُوْ إِلَيْكَ قَسْوَةَ قَلْبِنَا جَامِدُ",
      "فَكَيْفَ تَحْمِلُهَا إِذْكُنَّا نَسْتَرْشِدُ"
    ],
    [
      "اِلٰهَنَا الْطُفْ بِنَا يَا مَوْلٰنَا الْكَرِيْمُ",
      "بِبَرَكَاتِكَ يَا اُسْتَاذَنَا مَسْعُوْدُ"
    ],
    [
      "صَلَاةُ اللّٰهْ مَعْ سَلَامْ عَلَيْكَ يَا أَحْمَدُ",
      "نَبِيُّنَا الْمُجْتَبٰى وَالْمُصْطَفٰى مُرْشِدُ"
    ]
  ]
}
