  },
  "id": 17,
  "title": {
    "arabic": "اَلْإِعْتِرَاف",
    "latin": "Al-I'tiraf"
  },
  "content": [
    [
      "اِلٰهِىْ لَسْتُ لِلْفِرْدَوْسِ أَهْلاً",
      "وَلَا أَقْوٰى عَلَى نَارِ الْجَحِيمِ"
    ],
    [
      "فَهَبْ لِي تَوْبَةً وَّاغْفِرْ ذُنُونِي",
      "فَإِنَّكَ غَافِرُ الذَّنْبِ اْلعَظِيمِ"
    ],
    [
      "ذُنُونِي مِثْلُ أَعْدَادِ الرِّمَالِ",
      "فَهَبْ لِي تَوْبَةً يَّاذَا الجَلَالِ"
    ],
    [
      "وَعُمْرِىْ نَاقِصٌ فِي كُلِّ يَوْمٍ",
      "وَذَنْبِيْ زَائِدٌ كَيْفَ احْتِمَالِ"
    ],
    [
      "اِلهِٰي عَبْدُكَ الْعَاصِ أَتَاكَ",
      "مُقِرًّا بِالذُّنُوبِ وَقَدْ دَعَاكَ"
    ],
    [
      "فَإِنْ تَغْفِرْ فَانْتَ لِذَاكَ أَهْلٌ",
      "وَإِنْ تَطْرُدْ فَمَنْ نَرْجُو سِوَاكَ"
    ],
    [
      "شَكَوْتُ إِلٰى وَكِيعٍ سُوْءَ حِفْظِى",
      "فَأَرَشَدَنِي إِلٰى تَرْكِ الْمَعَاصِى"
    ],
    [
      "وَأَخْبَرَنِي بِأَنَّ الْعِلْمَ نُورٌ",
      "وَنُورُ اللّٰهِ لَا يُعْطٰى لِعَاصِى"
    ],
    [
      "فَإِنَّ الْحِفْظَ فَضْلٌ مِّنْ إِلٰهٍ",
      "وَفَضْلُ اللّٰهِ لَا يُعْطٰى لِعَاصِى"
    ]
  ]
}
