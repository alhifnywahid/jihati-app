  "id": 41,
  "title": {
    "arabic": "لَاݤُو مَارٓسْ فَسَنْتِرِيْن",
    "latin": "Lagu Mars Pesantren"
  },
  "content": [
    ["يَا رَبِّ صَلِّ عَلَى الرَّسُوْلِ", "مُحَمَّدٍ سِرِّ الْعُلَا"],
    ["وَالْأَنْبِيَآءِ وَالْمُرْسَلِينَ", "اَلغُرِّحَتْمًا أَوَّلَا"],
    ["بِقُدُوْمِكُمْ حَصَلَ السُّرُوْرُ", "فَعَمَّ كُلَّ الْحَاضِرِينَ"],
    ["بِقُدُوْمِكُمْ حَصَلَ الْهَنَاءْ", "كُلَّنَا دَلَّ الذَّاكِرِينَ"],
    ["اَلجَهْلُ دَآءٌ وَالْعِلْمُ يَشْفٖى", "وَهُوَ نِعْمَ الْمُقْتَنٰى"],
    ["إِذْ بِهٖ نَرْقٰى إلىٰ", "عَرْجِ السَّعَادَةِ وَالْهَنَآءُ"],
    ["اٰبَآئَنَا جُدُّوْا عَلَيْنَا", "وَانْصُرُوْا فِيٓ أَمْرِنَا"],
    ["عَلِّمُوْنَا سَادَتِيْ", "يَا مَرْحَبًا بِالْقَادِمِ"]
  ]
}
