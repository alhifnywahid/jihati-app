  },
  "id": 18,
  "title": {
    "arabic": "اِشْفَعْ لَنَا",
    "latin": "Isyfa' Lana"
  },
  "content": [
    [
      "ياَ سَيِّدِي شَمْسَ اْلوُجُودِ أَحْمَدَ",
      "اِشْفَعْ لَنَا عِنْدَ رَحِيمِنَا غَدَا"
    ],
    [
      "وَاسْئَلْ لَنَا رَبَّكَ حُسْنَ الخَاتِمَة",
      "وَاْلعَفْوَ وَالْعَافِيَة وَالسَّلاَمَة"
    ],
    [
      "وَالْعِلْمَ وَالْهُدٰى وَاْلاسْتِقَامَةْ",
      "وَالنُّوْرَ وَالنَّجَاةَ فِي الْقِيَامَةْ"
    ],
    [
      "وَاْلاَمْنَ وَالعِصْمَةَ وَالْكَرَامَةْ",
      "وَالْعِزَّ وَالأَمَانَ مِنْ ظلَامَةْ"
    ],
    [
      "وَالسِّرَّ وَالتَّوْفِيقِ وَالْقَنَاعَةْ",
      "وَالرِّزْقَ وَالسُّرُوْرَ وَالشَّفَاعَةْ"
    ],
    [
      "صَلَّى عَلَيْكَ اللّٰهُ يَا شَفِيْعَنَا",
      "يَا رَحْمَةَ اللّٰهِ عَلٰى جَمِيعِنَا"
    ]
  ]
}
